liation_labels":[]},{"metrics":[],"team_id":null,"result_id":"019d35c8-ab3d-749b-a505-68780c1a474b","time_text":null,"competitive":true,"course_rank":null,"status_code":"DNF","affiliations":[],"outcome_text":"DNF","overall_rank":null,"result_notes":null,"category_name":null,"category_rank":null,"individual_id":"019d356f-1525-706a-9f16-3ca0bc2bd9c4","metric_summary":null,"competitor_name":"Darcy deFreitas","competitor_type":"individual","additional_course":false,"affiliation_labels":[]}],"course_id":"019d356f-0c4f-7289-9c00-24f90edb3c76","course_name":"Course 3 - Long","distance_km":null,"result_count":24,"control_count":null,"course_climb_m":null}],"event_id":"019b81f3-1f4b-7ac5-b652-f7b996b2fe4b","venue_id":"019b81f3-1f39-78e6-aec8-62cd5da9502c","event_date":"2010-10-24","event_kind":"race","event_name":"Adventure Run/Goat-Ft. Ebey SP","venue_name":"Ft. Ebey State Park/Kettles County Park, Coupeville, Whidbey Island","event_notes":null,"course_count":3,"event_status":null,"result_count":45,"citation_count":2,"event_comments":"Result Status:\nFinal\nAbout 55 people attended the Adventure Run at Ft. Ebey SP. The weather report scared away some people from attending but it turned out to be an OK day. It turned out that Ft. Ebey SP ended up right in the middle of the Olympic Mtn rain shadow and no rain fell during the event at all. It was a bit windy with temps in the mid 50s but the sun made a few appearances and overall it was a good day for orienteering.\nThe last time an Adventure Run was held was a decade ago in 2000. The idea behind the format is that the checkpoints are not too technical so that beginners can take part. But the best routes will be to cut through the forest so good orienteers should have an advantage. The Adventure Run was done as a mass start and there were 3 courses. One checkpoint was allowed to be skipped to make it a little more interesting and more like a goat format. It turned out that most people skipped the same checkpoint number (#7) on courses 2 & 3. The first 6 checkpoints were the same for courses 2 & 3 and then deviated starting at #7 before coming together for the last 3 checkpoints.\nThis event also served as the annual Founder’s Day event for Cascade Orienteering Club in honor of the club’s founders. Eric Bone of Cascade OC won a tough battle with Magnus Johansson of Greater Vancouver Orienteering Club (GVOC) in Canada and is the winner of the Founder’s Day men’s award. The Founder’s Day women’s award goes to Andrea Balakova of GVOC, the women’s winner of the long course. The short course was won by Eileen Breseman of Cascade OC.","external_links":[],"volunteer_roles":[{"role_name":"Beginner Instruction","individual_id":"019d0a11-4d30-76bd-9f88-296000621d49","citation_count":1,"individual_name":"Patrick Nuss","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Setters","individual_id":"019b7ac9-920b-7139-aa9f-e67cde450b6c","citation_count":1,"individual_name":"Bill Cusworth","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Setters","individual_id":"019b9a64-7ffe-7d91-ba38-d8f6501c6d3d","citation_count":1,"individual_name":"Heidi Cusworth","volunteer_hours":null,"volunteer_points":null},{"role_name":"E-Punch Coordinator","individual_id":"019b7ac9-920b-7ef7-909c-53557520255d","citation_count":1,"individual_name":"Don Atkinson","volunteer_hours":null,"volunteer_points":null},{"role_name":"Equipment Transport","individual_id":"019d0a11-4d30-76bd-9f88-296000621d49","citation_count":1,"individual_name":"Patrick Nuss","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish","individual_id":"019b7adf-f250-735f-9fc9-46fd3e9119b1","citation_count":1,"individual_name":"Marjorie Stratton","volunteer_hours":null,"volunteer_points":null},{"role_name":"Marker Pick-up","individual_id":"019b7acf-182c-7c41-bf38-2f166390b465","citation_count":1,"individual_name":"Eric Bone","volunteer_hours":null,"volunteer_points":null},{"role_name":"Marker Pick-up","individual_id":"019b80fd-2e41-7304-a758-1cf15261e8c1","citation_count":1,"individual_name":"Jonathan Campbell","volunteer_hours":null,"volunteer_points":null},{"role_name":"Meet Directors","individual_id":"019b7ac9-920b-7139-aa9f-e67cde450b6c","citation_count":1,"individual_name":"Bill Cusworth","volunteer_hours":null,"volunteer_points":null},{"role_name":"Meet Directors","individual_id":"019b9a64-7ffe-7d91-ba38-d8f6501c6d3d","citation_count":1,"individual_name":"Heidi Cusworth","volunteer_hours":null,"volunteer_points":null},{"role_name":"Registration","individual_id":"019b7ac9-920b-738e-9c9a-52614be6cf3d","citation_count":1,"individual_name":"Eileen Breseman","volunteer_hours":null,"volunteer_points":null},{"role_name":"Registration","individual_id":"019d0a40-c41c-773c-b318-590bdbb49b85","citation_count":1,"individual_name":"Karl Rouillard","volunteer_hours":null,"volunteer_points":null},{"role_name":"Registration","individual_id":"019d0a40-c41f-7df7-a4e5-d3a1b3ec1772","citation_count":1,"individual_name":"Ryan Rouillard","volunteer_hours":null,"volunteer_points":null}],"organizing_club_id":"01912f3e-e3e1-7e8e-b3c6-32387a8b4990","result_source_brief":"Older COC Results Website: https://oldresults.cascadeoc.org/results/2010/adventure-rungoat-ft-ebey-sp.html","organizing_club_name":"Cascade Orienteering Club","cumulative_event_comments":"Result Status:\nFinal\nAbout 55 people attended the Adventure Run at Ft. Ebey SP. The weather report scared away some people from attending but it turned out to be an OK day. It turned out that Ft. Ebey SP ended up right in the middle of the Olympic Mtn rain shadow and no rain fell during the event at all. It was a bit windy with temps in the mid 50s but the sun made a few appearances and overall it was a good day for orienteering.\nThe last time an Adventure Run was held was a decade ago in 2000. The idea behind the format is that the checkpoints are not too technical so that beginners can take part. But the best routes will be to cut through the forest so good orienteers should have an advantage. The Adventure Run was done as a mass start and there were 3 courses. One checkpoint was allowed to be skipped to make it a little more interesting and more like a goat format. It turned out that most people skipped the same checkpoint number (#7) on courses 2 & 3. The first 6 checkpoints were the same for courses 2 & 3 and then deviated starting at #7 before coming together for the last 3 checkpoints.\nThis event also served as the annual Founder’s Day event for Cascade Orienteering Club in honor of the club’s founders. Eric Bone of Cascade OC won a tough battle with Magnus Johansson of Greater Vancouver Orienteering Club (GVOC) in Canada and is the winner of the Founder’s Day men’s award. The Founder’s Day women’s award goes to Andrea Balakova of GVOC, the women’s winner of the long course. The short course was won by Eileen Breseman of Cascade OC."}
