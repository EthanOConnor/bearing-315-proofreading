-c762-7bd1-8bbe-6c84d8a2e4e4","course_name":"Course 5","distance_km":8,"result_count":10,"control_count":23,"course_climb_m":null}],"event_id":"019b7b62-9f5f-728b-9849-a6da5e3d80df","venue_id":"019b7b62-9f59-7108-a468-484c9810028f","event_date":"1999-10-09","event_kind":"race","event_name":"Fort Casey State Park","venue_name":"Fort Casey State Park","event_notes":"Separate 1.2 km beginner course. Loop format: A-D ~2 km each with map exchange at start/finish; Course 2 = Loop D; Course 3 = Loops A+B; Course 4 = Loops A+B+C; Course 5 = Loops A+B+C+D. Narrative notes concrete gun batteries and stairways/ladders.","course_count":6,"event_status":null,"result_count":47,"citation_count":5,"event_comments":"Beautiful weather brought a good crowd out to Fort Casey on Whidbey Island. The concrete gun batteries always provide a navigational challenge with their stairways and ladders, and this meet was no exception.\nCourse designer Paul Magnus set up a separate 1.2k course for beginners. Everyone else could choose between 1, 2, 3, or all 4 of the 2k loops, passing through the start/finish area to exchange maps after each.\nMany thanks to Paul Magnus for setting courses and acquiring land permission.","external_links":[],"volunteer_roles":[{"role_name":"Course Designer","individual_id":"019b7ad3-42ab-78e7-a8a8-ea79149e1216","citation_count":1,"individual_name":"Paul Magnus","volunteer_hours":null,"volunteer_points":null},{"role_name":"Marker Pickup","individual_id":"019b7ad3-42ab-78e7-a8a8-ea79149e1216","citation_count":1,"individual_name":"Paul Magnus","volunteer_hours":null,"volunteer_points":null},{"role_name":"Meet Director","individual_id":"019b7ac9-920b-797d-8bf4-ebd4508c4277","citation_count":1,"individual_name":"Dave Tallent","volunteer_hours":null,"volunteer_points":null},{"role_name":"Meet Director","individual_id":"01913919-da03-757e-b829-aa2bdc684400","citation_count":1,"individual_name":"Debbie Newell","volunteer_hours":null,"volunteer_points":null},{"role_name":"Registration","individual_id":"01913919-da03-757e-b829-aa2bdc684400","citation_count":1,"individual_name":"Debbie Newell","volunteer_hours":null,"volunteer_points":null},{"role_name":"Start/Finish","individual_id":"019b7ac9-920b-797d-8bf4-ebd4508c4277","citation_count":1,"individual_name":"Dave Tallent","volunteer_hours":null,"volunteer_points":null},{"role_name":"Start/Finish","individual_id":"019b7ac9-920b-7f3d-8bc9-eb2b998ae352","citation_count":1,"individual_name":"Randy Brasfield","volunteer_hours":null,"volunteer_points":null}],"organizing_club_id":"01912f3e-e3e1-7e8e-b3c6-32387a8b4990","result_source_brief":"Web Snapshot: Fort Casey State Park (1999-10-09)","organizing_club_name":"Cascade Orienteering Club","cumulative_event_comments":"Beautiful weather brought a good crowd out to Fort Casey on Whidbey Island. The concrete gun batteries always provide a navigational challenge with their stairways and ladders, and this meet was no exception.\nCourse designer Paul Magnus set up a separate 1.2k course for beginners. Everyone else could choose between 1, 2, 3, or all 4 of the 2k loops, passing through the start/finish area to exchange maps after each.\nMany thanks to Paul Magnus for setting courses and acquiring land permission."}
