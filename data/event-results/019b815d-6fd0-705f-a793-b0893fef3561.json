e":"Roland & Natasha Mueller","competitor_type":"team","additional_course":false,"affiliation_labels":[]},{"metrics":[],"team_id":null,"result_id":"019d35c8-aaa9-790a-979b-fbf1ada413b1","time_text":"01:10:51","competitive":true,"course_rank":5,"status_code":"OK","affiliations":[],"outcome_text":"01:10:51","overall_rank":5,"result_notes":null,"category_name":null,"category_rank":null,"individual_id":"019b7acf-182c-7982-8ac1-0e7bd8601a59","metric_summary":null,"competitor_name":"Ron Brown","competitor_type":"individual","additional_course":false,"affiliation_labels":[]},{"metrics":[],"team_id":null,"result_id":"019d35c8-aaa9-7835-88bb-941714db8053","time_text":"01:07:51","competitive":true,"course_rank":6,"status_code":"OK","affiliations":[],"outcome_text":"01:07:51","overall_rank":6,"result_notes":"On foot","category_name":null,"category_rank":null,"individual_id":"019b7acf-182c-705a-a8fe-e71bcacc38a6","metric_summary":null,"competitor_name":"Kean Williams","competitor_type":"individual","additional_course":false,"affiliation_labels":[]},{"metrics":[],"team_id":"019b815e-ccf2-733a-b481-0a3a2a3372ca","result_id":"019d35c8-aaa9-736f-ad9c-2b919c52af60","time_text":null,"competitive":false,"course_rank":null,"status_code":"NC","affiliations":[],"outcome_text":"NC","overall_rank":null,"result_notes":"fun riders","category_name":null,"category_rank":null,"individual_id":null,"metric_summary":null,"competitor_name":"Mike Drouillard (+1)","competitor_type":"team","additional_course":false,"affiliation_labels":[]}],"course_id":"019b815d-8830-76cc-8bae-673f10f976ae","course_name":"Course 4","distance_km":12,"result_count":7,"control_count":12,"course_climb_m":null}],"event_id":"019b815d-6fd0-705f-a793-b0893fef3561","venue_id":"019b80fa-1f49-7aac-af1e-a26a076d1964","event_date":"2002-07-21","event_kind":"race","event_name":"Ballard Bike-O","venue_name":"Ballard","event_notes":"Attendance record of 29 participants; Pat Kelly biked the longest course then ran the 6 km course; courses visited the Nordic Heritage Museum with flag questions. — Harvey Friedman.","course_count":4,"event_status":null,"result_count":19,"citation_count":2,"event_comments":"Having the registration/start/finish/socialization area at the SW corner of the Ballard Community Center block on NW 60th St. & 28th Ave. NW was so pleasant that 5 of the 18 people who participated last summer returned for more. Thanks to the Sprugel family and their friends, we set a new attendance record for bike-O with a grand total of 29 people who did at least 1 course. Pat Kelly did the ironman stint, bicyling the longest course and then running the 6 km. course. Ken Lew demonstrated that we only get better with age as he improved from 57:10 last year to 56:45 this year for same course. All 4 courses visited the Nordic Heritage Museum but each had a different question to answer since there are 5 flags (of the 5 Nordic countries) painted on the west wall. More people named the flag wrong than any other question, although some definitely had the wrong intersection on other legs. Maybe next year we can have a 5-minute penalty for each wrong answer. For those who think that the hydrant color question was too easy, I saw green, blue, red, and yellow painted hydrants when picking controls for these courses.\nHarvey Friedman -- meet director","external_links":[],"volunteer_roles":[{"role_name":"Control Pickup","individual_id":"019b8163-5203-7382-9b96-3cde35888399","citation_count":1,"individual_name":"Anne York","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019b8163-5204-757f-889d-4e0cd497f294","citation_count":1,"individual_name":"Harvey Friedman","volunteer_hours":null,"volunteer_points":null},{"role_name":"Meet Director/Course Design","individual_id":"019b8163-5204-757f-889d-4e0cd497f294","citation_count":1,"individual_name":"Harvey Friedman","volunteer_hours":null,"volunteer_points":null},{"role_name":"Start/Finish","individual_id":"019b8163-5203-7382-9b96-3cde35888399","citation_count":1,"individual_name":"Anne York","volunteer_hours":null,"volunteer_points":null}],"organizing_club_id":"01912f3e-e3e1-7e8e-b3c6-32387a8b4990","result_source_brief":"Older COC Results Website: http://www.old.cascadeoc.org/Results2002/bikeo.html","organizing_club_name":"Cascade Orienteering Club","cumulative_event_comments":"Having the registration/start/finish/socialization area at the SW corner of the Ballard Community Center block on NW 60th St. & 28th Ave. NW was so pleasant that 5 of the 18 people who participated last summer returned for more. Thanks to the Sprugel family and their friends, we set a new attendance record for bike-O with a grand total of 29 people who did at least 1 course. Pat Kelly did the ironman stint, bicyling the longest course and then running the 6 km. course. Ken Lew demonstrated that we only get better with age as he improved from 57:10 last year to 56:45 this year for same course. All 4 courses visited the Nordic Heritage Museum but each had a different question to answer since there are 5 flags (of the 5 Nordic countries) painted on the west wall. More people named the flag wrong than any other question, although some definitely had the wrong intersection on other legs. Maybe next year we can have a 5-minute penalty for each wrong answer. For those who think that the hydrant color question was too easy, I saw green, blue, red, and yellow painted hydrants when picking controls for these courses.\nHarvey Friedman -- meet director"}
