ult_id":"019d0f4d-7e0e-7880-9c99-13ee1c182c7d","time_text":null,"competitive":true,"course_rank":null,"status_code":"MSP","affiliations":[],"outcome_text":"MSP","overall_rank":14,"result_notes":"leg_1 MP; leg_1 route_code BDCF; leg_2 route_code LEG2; leg_3 route_code ACDE","category_name":"Open","category_rank":null,"individual_id":null,"metric_summary":"Leg 2 Time 00:29:04; Leg 3 Time 00:29:33","competitor_name":"AZR","competitor_type":"team","additional_course":false,"affiliation_labels":[]}],"course_id":"019d0f4d-7e57-7a0c-a687-6e525dc5550a","course_name":"Relay","distance_km":null,"result_count":14,"control_count":null,"course_climb_m":null}],"event_id":"019b81f3-1f4d-71e9-a52f-6ede46cb093a","venue_id":"019b81f3-1f39-7e1d-afe3-ae19e64bef48","event_date":"2018-02-18","event_kind":"race","event_name":"Winter O / WIOL Bonus Relay","venue_name":"South Seattle College","event_notes":null,"course_count":1,"event_status":null,"result_count":14,"citation_count":3,"event_comments":"Last year we introduced an exciting way to end the winter season: a 3-person relay! It was so much fun, we decided to do it again. There are two classes: Open and Juniors (20 years and younger). School teams will consist of at least one male and one female. Open teams will also have a mix of at least one male and one female. This event is not part of the WIOL season, and there are no restrictions on who may be on your team – same school, different schools, not in school, whatever. All WIOL participants need to register on the COC website using the linked form. The WIOL registration is not set up for this relay.\nCourses are not designed yet but last year, Legs 1 and 3 were similar in distance and difficulty. They both had forking, so you can’t assume that anybody else has the same order of the controls as you have. It will be very important to check both control codes and control descriptions! Leg 2 had the difficulty of Advanced Beginner with no forking and was suitable for those with less navigation experience and/or physical endurance. When you finish your leg, leave the map at the Download, and please do not cheat and talk with your teammates about the courses to make it fair play for everybody.\nPre-registration is strongly encouraged to ensure a spot. The fee for pre-registration is $2. We will have a limited number of maps available for registration on the day of the event and it is first come, first serve. And a higher entry fee ($20) for the day-of registration.\nEvery participant has to register individually. When you register, please enter the names of the three team members. We need to know in which order the team members are running since everybody on the team has a different map. If you don’t have a team, please write on the form that you want to be placed on a team.\nOnline pre-registration closes: 8:00 AM, Friday, February 16\nCheck back later for special notes from the Course Designer(s).","external_links":[{"link_url":"https://www.google.com/maps/place/47%C2%B032'46.9%22N+122%C2%B021'12.8%22W/@47.5463556,-122.3557537,17z/data=!3m1!4b1!4m6!3m5!1s0x0:0x0!7e2!8m2!3d47.5463521!4d-122.3535649","link_type":"directions"},{"link_url":"https://cascadeoc.org/event/winter-wiol-relays/","link_type":"event_page"},{"link_url":"https://cascadeoc.org/map/south-seattle-college/","link_type":"map"},{"link_url":"http://cascadeoc.org/series/school-league-wiol/","link_type":"series"},{"link_url":"https://cascadeoc.org/series/school-league-wiol/","link_type":"series"}],"volunteer_roles":[{"role_name":"Course Designer","individual_id":"019b7ac9-920b-7530-b85a-103e52302ff8","citation_count":2,"individual_name":"Will Enger","volunteer_hours":null,"volunteer_points":null},{"role_name":"Epunch Coordinator","individual_id":"019d0a11-4d2f-7807-bdc6-77a7e939a3ae","citation_count":1,"individual_name":"Eric Jones","volunteer_hours":null,"volunteer_points":null},{"role_name":"Event Staff/Volunteers","individual_id":"019b7fed-a88a-793a-93fe-92fdcebd84c4","citation_count