me":"Seattle Pacific University","event_notes":null,"course_count":2,"event_status":null,"result_count":67,"citation_count":3,"event_comments":"This was a forked relay, so while each team completed every possible leg, every individual ran a unique combination of those legs.\nAll courses were set up as follows: 101 – ABC – 124 – DEF – 133 – GHI – 137 – 110 – 120 – 111 – 112 – JKL – 118. Each group of letters represents a fork where (for example) one of your team members had A, one had B, and one had C. Each fork was 2-4 controls before meeting back up at the next common control.\nTo find your individual splits for all checkpoints, use the four letter code next to your name to select the correct course on RouteGadget.\nTo compare splits against everyone else visiting common controls, use the '(Open/Junior) 20-22 common controls' link on RouteGadget.","external_links":[{"link_url":"https://cascadeoc.org/event/2019-winter-league-relay/","link_type":"event_page"},{"link_url":"http://obasen.orientering.se/winsplits/online/en/default.asp?page=classes&databaseId=60723","link_type":"splits"},{"link_url":"http://rg.cascadeoc.org/rg2/#240","link_type":"splits"}],"volunteer_roles":[{"team_id":null,"role_name":"Control Pickup","team_name":null,"individual_id":"019d0a11-4d2f-7780-8db0-47a6d8b7327c","citation_count":1,"individual_name":"Ethan O'Connor","volunteer_hours":null,"volunteer_points":null},{"team_id":null,"role_name":"Control Pickup","team_name":null,"individual_id":"019d0a11-4d30-734a-9efe-884bfcb2a0e8","citation_count":1,"individual_name":"Linnea Nasman","volunteer_hours":null,"volunteer_points":null},{"team_id":null,"role_name":"Control Pickup","team_name":null,"individual_id":"019d0a11-4d30-77b1-a76e-9b43c33599f2","citation_count":1,"individual_name":"Shannon Cheng","volunteer_hours":null,"volunteer_points":null},{"team_id":null,"role_name":"Course Designer","team_name":null,"individual_id":"019d0a40-c41c-7a52-b827-d9860d8b9f95","citation_count":1,"individual_name":"