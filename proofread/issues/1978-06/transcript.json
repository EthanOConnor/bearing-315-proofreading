      "block_id": "1978-06-heading-855e3d39f5-1",
      "kind": "heading",
      "text": "MEETINGS - MEETS - MEMBERSHIPS",
      "text_length": 30
    },
    {
      "block_id": "1978-06-paragraph-963b87c054-1",
      "kind": "paragraph",
      "text": "For answers or information:",
      "text_length": 27
    },
    {
      "block_id": "1978-06-list_item-de02a197a6-1",
      "kind": "list_item",
      "text": "President: Karl Nolte - 632-5559",
      "text_length": 32
    },
    {
      "block_id": "1978-06-list_item-5187e8dbf5-1",
      "kind": "list_item",
      "text": "Vice President: Tom Stewart (Tacoma) - 964-4309",
      "text_length": 47
    },
    {
      "block_id": "1978-06-list_item-4c16c03e3e-1",
      "kind": "list_item",
      "text": "Secretary: Stan Hochman - 746-8028",
