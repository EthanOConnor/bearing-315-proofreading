    {
      "block_id": "1978-06-paragraph-6e48c739f5-1",
      "kind": "paragraph",
      "text": "The above books available from: Runner's Book Warehouse P.O. Box 7251 Mountain View, CA 94042 (When ordering, add .45\u00a2 per book for mailing costs)",
