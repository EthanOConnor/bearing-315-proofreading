k and back, while Courses 1 and 3 will remain within the wooded hillsides of Hamlin Park proper.","external_links":[{"link_url":"https://www.google.com/maps/place/47%C2%B044'44.2%22N+122%C2%B018'34.0%22W/@47.7456048,-122.3111286,578m/data=!3m2!1e3!4b1!4m6!3m5!1s0x0:0x0!7e2!8m2!3d47.7456015!4d-122.3094465","link_type":"directions"},{"link_url":"https://cascadeoc.org/event/2019-wednesday-evening-2-hamlin-park/","link_type":"event_page"},{"link_url":"https://cascadeoc.org/map/hamlin-park-2/","link_type":"map"},{"link_url":"http://rg.cascadeoc.org/rg2/#250","link_type":"routegadget"},{"link_url":"https://cascadeoc.org/series/wednesday-evening/","link_type":"series"},{"link_url":"http://obasen.orientering.se/winsplits/online/en/default.asp?page=classes&databaseId=63373","link_type":"splits"}],"volunteer_roles":[{"role_name":"Control Pickup","individual_id":"019d0a11-4d2f-736d-863f-5e546e61e969","citation_count":1,"individual_name":"Ing Uhlin","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"0191394f-d748-7189-887f-793488143b6d","citation_count":1,"individual_name":"Mike Schuh","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0e9a-060a-7257-b757-d1b073cd6d47","citation_count":1,"individual_name":"Rebecca Stratton","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Designer","individual_id":"019b7ac9-920b-7530-b85a-103e52302ff8","citation_count":1,"individual_name":"Will Enger","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Designer(s)","individual_id":"019b7ac9-920b-7530-b85a-103e52302ff8","citation_count":1,"individual_name":"Will Enger","volunteer_hours":null,"volunteer_points":null},{"role_name":"Epunch Coordinator","individual_id":"01913919-da03-757e-b829-aa2bdc684400","citation_count":1,"individual_name":"Debbie Newell","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish","individual_id":"01913919-da03-757e-b829-aa2b