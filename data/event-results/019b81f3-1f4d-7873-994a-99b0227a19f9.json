ull,"individual_id":"019d0a11-4d30-7112-ab4b-561aafee688a","metric_summary":null,"competitor_name":"Jennifer Castelluccio","competitor_type":"individual","additional_course":false,"affiliation_labels":[]},{"metrics":[],"team_id":null,"result_id":"019d0f21-20cf-7eba-a48f-e8ca2d1e18ab","time_text":null,"competitive":true,"course_rank":null,"status_code":"MSP","affiliations":[],"outcome_text":"MSP","overall_rank":null,"result_notes":"54:24","category_name":null,"category_rank":null,"individual_id":"019b7b13-321a-7dac-ae5d-c8ec343589f7","metric_summary":null,"competitor_name":"Tyler Frederickson","competitor_type":"individual","additional_course":false,"affiliation_labels":[]}],"course_id":"019d0f21-2176-7ddc-b159-791406582988","course_name":"Course4","distance_km":null,"result_count":23,"control_count":null,"course_climb_m":null}],"event_id":"019b81f3-1f4d-7873-994a-99b0227a19f9","venue_id":"019b81b3-75d1-7c6d-9d3f-3a8112e85fd0","event_date":"2019-07-17","event_kind":"race","event_name":"2019 Wednesday Evening #4","venue_name":"North Seatac Park","event_notes":null,"course_count":4,"event_status":null,"result_count":51,"citation_count":3,"event_comments":"The fourth event in the 2019 Wednesday Evening Series will be held at North SeaTac Park! The Wednesday Evening Series is our most relaxed, casual set of navigation events, held in local parks once the weather warms up. These events are a little more low-key than those in the Winter League, and we typically offer a barbeque afterward for all participants. Decompress after work and bring a coworker or two along. Or meet your family at the park and enjoy a night off from cooking. Or meet a bunch of friends at the park for an evening of exploring together, chatting over some food, and finishing up with frisbee on the lawn.\nEvents in the Wednesday Evening Series are generally less challenging (both physically and navigationally) than many of our other events, and are therefore great for beginners and those less experienced with orienteering – while also offering a challenge to longtime participants of the sport.\nNorth Seatac Park is a surprisingly complicated little venue, with a sometimes maze-like mix of vegetation including green thickets, white forest, and yellow open clearings, with a nice collection of trails and an array of point features including boulders and various manmade objects – many of which are part of the disc golf course which weaves throughout the northern half of the park. The park is almost entirely flat, so you generally won’t be able to use contours for navigation and, once you’re off-trail, will primarily need to rely on close reading of vegetation.\nAlso, note that all courses will remain in the northern half of the park, north of 136th Street, due to a bicycle race taking place in the areas to the south of the road. As such, there will be a lot of controls in a relatively small area, so be sure to check your control codes!","external_links":[{"link_url":"https://goo.gl/maps/MfmM35eXCo4piXLV9","link_type":"directions"},{"link_url":"https://cascadeoc.org/event/2019-wednesday-evening-4-north-seatac-park/","link_type":"event_page"},{"link_url":"https://cascadeoc.org/map/north-seatac-park/","link_type":"map"},{"link_url":"http://rg.cascadeoc.org/rg2/#253","link_type":"routegadget"},{"link_url":"https://cascadeoc.org/series/wednesday-evening/","link_type":"series"},{"link_url":"http://obasen.orientering.se/winsplits/online/en/default.asp?page=classes&databaseId=64283","link_type":"splits"}],"volunteer_roles":[{"role_name":"Control Pickup","individual_id":"019d0a11-4d2f-7807-bdc6-77a7e939a3ae","citation_count":1,"individual_name":"Eric Jones","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a40-c41c-7534-9c1e-89cf1709d9d0","citation_count":1,"individual_name":"Jud Kelley","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"0191394f-d748-7189-887f-793488143b6d","citation