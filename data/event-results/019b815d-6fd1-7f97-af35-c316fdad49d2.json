_code":"OVT","affiliations":[],"outcome_text":"OVT 04:00:30","overall_rank":null,"result_notes":"Source row wraps across two lines; Source includes dog as part of team label","category_name":null,"category_rank":null,"individual_id":null,"metric_summary":"Controls Found 4; Penalty 31; Points 0","competitor_name":"Jim Bogesvang/Harish Abbott/dog","competitor_type":"team","additional_course":false,"affiliation_labels":[]}],"course_id":"019b815d-8831-7c02-ac05-c193fc9ce46a","course_name":"Score-O","distance_km":null,"result_count":18,"control_count":18,"course_climb_m":null}],"event_id":"019b815d-6fd1-7f97-af35-c316fdad49d2","venue_id":"019b815a-c65f-738f-ae32-10c7219d7c56","event_date":"2002-10-05","event_kind":"race","event_name":"Salmon La Sac Score-O","venue_name":"Salmon La Sac","event_notes":"23 people and one dog enjoyed good weather and an 18-control score-O; calls for a new orienteering map; thanks to registration and control pickup volunteers. — Eric Bone.","course_count":1,"event_status":null,"result_count":18,"citation_count":2,"event_comments":"23 people and one dog enjoyed good weather, autumn colors, and a challenging, 18-control score orienteering course at Salmon La Sac.\nSome of the controls were probably too technical for what the USGS map would support, but the participants were good sports about it.\nAs usual, some people raced, while others made a leisurely hike of it, taking their time to explore the unique landscape.\nThe terrain at this new venue received good reviews and several calls for an orienteering map to be made.\nThanks to Jon and Tori Campbell for working registration and to Joel and Justin Yeager, Amber Shaffer, Matthew Church, Anastasia Telesetski, Mike Schuh, and Ginger Stratton for control pick-up.\nA special thanks to Ginger Stratton, who not only drove me and the equipment to the event site and back, but waited for me to pick up controls (after picking some up herself).\nEric Bone","external_links":[],"volunteer_roles":[{"role_name":"Courses","individual_id":"019b7acf-182c-7c41-bf38-2f166390b465","citation_count":1,"individual_name":"Eric Bone","volunteer_hours":null,"volunteer_points":null},{"role_name":"Meet Director","individual_id":"019b7acf-182c-7c41-bf38-2f166390b465","citation_count":1,"individual_name":"Eric Bone","volunteer_hours":null,"volunteer_points":null},{"role_name":"Registration","individual_id":"019b8046-0f3f-73b2-8a98-ffb0faf59c4f","citation_count":1,"individual_name":"Jon Campbell","volunteer_hours":null,"volunteer_points":null},{"role_name":"Registration","individual_id":"019b811c-3e18-7790-8d31-3b5d69d7ce5e","citation_count":1,"individual_name":"Tori Campbell","volunteer_hours":null,"volunteer_points":null}],"organizing_club_id":"01912f3e-e3e1-7e8e-b3c6-32387a8b4990","result_source_brief":"Older COC Results Website: http://www.old.cascadeoc.org/Results2002/salmon.html","organizing_club_name":"Cascade Orienteering Club","cumulative_event_comments":"23 people and one dog enjoyed good weather, autumn colors, and a challenging, 18-control score orienteering course at Salmon La Sac.\nSome of the controls were probably too technical for what the USGS map would support, but the participants were good sports about it.\nAs usual, some people raced, while others made a leisurely hike of it, taking their time to explore the unique landscape.\nThe terrain at this new venue received good reviews and several calls for an orienteering map to be made.\nThanks to Jon and Tori Campbell for working registration and to Joel and Justin Yeager, Amber Shaffer, Matthew Church, Anastasia Telesetski, Mike Schuh, and Ginger Stratton for control pick-up.\nA special thanks to Ginger Stratton, who not only drove me and the equipment to the event site and back, but waited for me to pick up controls (after picking some up herself).\nEric Bone"}
