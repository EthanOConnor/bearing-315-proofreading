ve":true,"course_rank":null,"status_code":"MSP","affiliations":[{"label":"COC"}],"outcome_text":"MSP","overall_rank":7,"result_notes":"234:42","category_name":"Bog Slog – Group","category_rank":null,"individual_id":null,"metric_summary":null,"competitor_name":"Ben Brumback Group","competitor_type":"team","additional_course":false,"affiliation_labels":["COC"]},{"metrics":[],"team_id":"019d0a11-4d4f-7e07-a721-042164b56d33","result_id":"019d0a11-4cdf-7a54-bf11-dff2cc1db60c","time_text":null,"competitive":true,"course_rank":null,"status_code":"DNF","affiliations":[{"label":"COC"}],"outcome_text":"DNF","overall_rank":8,"result_notes":"200:14","category_name":"Bog Slog – Group","category_rank":null,"individual_id":null,"metric_summary":null,"competitor_name":"Peter Krantwald Group","competitor_type":"team","additional_course":false,"affiliation_labels":["COC"]}],"course_id":"019d0a11-4d1d-7642-ae38-a2b361f2ab17","course_name":"Overall","distance_km":null,"result_count":8,"control_count":null,"course_climb_m":null}],"event_id":"019b81f3-1f4e-737a-bc39-fb0baf22cbab","venue_id":"019b81f3-1f39-7e9a-b15e-62ef1a8a72ea","event_date":"2019-12-29","event_kind":"race","event_name":"2019 Choose Your Adventure #5: The Bog Slog and Jog","venue_name":"Lord Hill Regional Park","event_notes":null,"course_count":5,"event_status":null,"result_count":69,"citation_count":4,"event_comments":"The Bog Slog, now in its 40th year, is the extra tough and extra muddy halftime race to the Winter League, and a fantastic opportunity for students who have graduated from WIOL to return for a holiday reunion with friends!\nThe Bog Slog now concludes the Choose Your Adventure Series, which means that we are still offering offering two mass-start, point-to-point courses for the advanced runners, as well as a Choose Your Adventure style race for beginners, intermediates, and trail runners!\nThis year, as in recent years, we will have a separate mass start for each course. See the schedule for course start times.\nIf you’re a runner, this means an opportunity to stay with similarly-paced runners on the same course until elevation gain and navigational challenges split the pack.\nIf you’re a hiker, this means that you don’t wait long for a start, and the herd of running orienteers departs rather quickly, leaving you with a nice hike-with-a-purpose through Lord Hill Park.\nAs always, The Bog Slog advanced courses are longer and more challenging than our usual Winter League courses. Some participants drop down a level for ease, while others treat this as the ultimate challenge, often sharing the navigation fun and bragging rights for completion.\nLord Hill Park is a large wooded park with a great variety of vegetation and an extensive trail system. Trails vary from wide gravel roads to narrow trails. Vegetation varies off trail from run-able to fight. Full body cover is recommended.\nHazards include slippery trails, steep elevation change and varying levels of vegetation on the off trail routes. Be wary of icy patches in cold weather.","external_links":[{"link_url":"https://www.google.com/maps/dir//47.8333207,-122.044996/@47.8335296,-122.0445346,1667m/data=!3m1!1e3!4m2!4m1!3e0","link_type":"directions"},{"link_url":"https://cascadeoc.org/map/lord-hill-regional-park/","link_type":"map"},{"link_url":"https://cascadeoc.org/series/adventure/","link_type":"series"}],"volunteer_roles":[{"role_name":"Course Designer","individual_id":"019d0a11-4d2f-7780-8db0-47a6d8b7327c","citation_count":1,"individual_name":"Ethan O'Connor","volunteer_hours":null,"volunteer_points":null}],"organizing_club_id":"01912f3e-e3e1-7e8e-b3c6-32387a8b4990","result_source_brief":"CascadeOC Website: https://cascadeoc.org/result/2019-choose-adventure-5-bog-slog-jog/","organizing_club_name":"Cascade Orienteering Club","cumulative_event_comments":"The Bog Slog, now in its 40th year, is the extra tough and extra muddy halftime race to the Winter League, and a fantastic opportunity for students who have graduated from WIOL to return for a holiday reunion with friends!\nThe Bog Slog now concludes the Choose Your Adventure Series, which means that we are still offering offering two mass-start, point-to-point courses for the advanced runners, as well as a Choose Your Adventure style race for beginners, intermediates, and trail runners!\nThis year, as in recent years, we will have a separate mass start for each course. See the schedule for course start times.\nIf you’re a runner, this means an opportunity to stay with similarly-paced runners on the same course until elevation gain and navigational challenges split the pack.\nIf you’re a hiker, this means that you don’t wait long for a start, and the herd of running orienteers departs rather quickly, leaving you with a nice hike-with-a-purpose through Lord Hill Park.\nAs always, The Bog Slog advanced courses are longer and more challenging than our usual Winter League courses. Some participants drop down a level for ease, while others treat this as the ultimate challenge, often sharing the navigation fun and bragging rights for completion.\nLord Hill Park is a large wooded park with a great variety of vegetation and an extensive trail system. Trails vary from wide gravel roads to narrow trails. Vegetation varies off trail from run-able to fight. Full body cover is recommended.\nHazards include slippery trails, steep elevation change and varying levels of vegetation on the off trail routes. Be wary of icy patches in cold weather."}
