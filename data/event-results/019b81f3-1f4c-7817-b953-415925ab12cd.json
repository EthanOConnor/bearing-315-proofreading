oints","metric_numeric":0}],"team_id":null,"result_id":"019d0f21-20dd-7e9f-9cb6-7725f4fed27c","time_text":"00:50:00","competitive":true,"course_rank":81,"status_code":"OK","affiliations":[],"outcome_text":"00:50:00","overall_rank":81,"result_notes":"controls Lost Card","category_name":null,"category_rank":null,"individual_id":"019d0a40-c41f-7edd-8acb-afe72df9d2f5","metric_summary":"Points 0","competitor_name":"Ryan Brombaugh","competitor_type":"individual","additional_course":false,"affiliation_labels":[]}],"course_id":"019d0f21-2179-7c8f-8a52-be5ffa781482","course_name":"Special thanks to our volunteers:","distance_km":null,"result_count":81,"control_count":null,"course_climb_m":null}],"event_id":"019b81f3-1f4c-7817-b953-415925ab12cd","venue_id":"019b81f3-1f39-756c-9a1e-ccb8617bf543","event_date":"2016-10-29","event_kind":"race","event_name":"Choose Your Adventure: Vampire!","venue_name":"Lake Wilderness Park","event_notes":null,"course_count":1,"event_status":null,"result_count":81,"citation_count":3,"event_comments":"Vampires: Julie Cassata, Logan Davis, (Jack Leavitt? No finish record)\n\nThe Choose Your Adventure Series is meant to be fun, social, friendly for beginners, yet interesting for seasoned veterans. Everyone starts together, so run head-to-head with your friends or against your rivals. Who will visit the most checkpoints within the time limit? Who will run the fastest? And with vampires roaming the woods at this event, who will avoid getting bitten?\nThis format is great for beginners! With many checkpoints along trails and open areas, you’ll be sure to visit a lot! And if there’s one that’s hard to find, don’t worry, you can skip it and keep going. For the advanced navigators, the races will be a challenging exercise in figuring out the most efficient and optimal route to try to get them all (and avoid the vampires)!\nObviously, vampires are only out at night, so you’ll need to bring a flashlight or headlamp! Come join the fun!\nIs this your first event or do you want to improve your skills? Meet us from 5:30pm – 6:30pm for up to an hour of free skills instruction!","external_links":[{"link_url":"https://goo.gl/maps/p2hdBNyhYz92","link_type":"directions"},{"link_url":"https://cascadeoc.org/event/vampire2016/","link_type":"event_page"},{"link_url":"https://cascadeoc.org/map/lake-wilderness-park/","link_type":"map"},{"link_url":"https://cascadeoc.org/series/adventure/","link_type":"series"}],"volunteer_roles":[{"role_name":"Control Pickup","individual_id":"0191394f-d748-7189-887f-793488143b6d","citation_count":1,"individual_name":"Mike Schuh","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a11-4d30-78eb-b020-1c8126101cc0","citation_count":1,"individual_name":"Sherri Brady","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Designer","individual_id":"019d0a11-4d30-78eb-b020-1c8126101cc0","citation_count":1,"individual_name":"Sherri Brady","volunteer_hours":null,"volunteer_points":null},{"role_name":"Epunch Coordinator","individual_id":"019b7b20-7ab2-7846-b657-3dade4d53276","citation_count":1,"individual_name":"Bob Forgrave","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish line","individual_id":"019d0e9a-0607-7beb-b0b2-a2841ea0b68b","citation_count":1,"individual_name":"Ben Brady","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish line","individual_id":"019b7b20-7ab2-7846-b657-3dade4d53276","citation_count":1,"individual_name":"Bob Forgrave","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish line","individual_id":"019d0a40-c41c-7454-b926-556b932d16e5","citation_count":1,"individual_name":"John Brady","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish line","individual_id":"019d0a11-4d30-7344-8bf5-5763194212b0","citation_count":1,"individual_name":"Kathy Forgrave","volunteer_hours":null,"volunteer_points":null},{"role_name":"Finish line","individual_id":"019d0a11-4d30-78eb-b