ult_count":35,"citation_count":3,"event_comments":"Control 122 was not placed until after the start of the event, so it was awarded to all participants except when it was known for sure that they did not visit it.\nControls 121 and 136 were swapped during the event after confusion on the map; both controls were eventually placed in both locations to reduce further confusion.\nThank you to all volunteers for helping make this event a success!","external_links":[{"link_url":"https://cascadeoc.org/event/bogslog2019/","link_type":"event_page"},{"link_url":"https://cascadeoc.org/series/adventure/","link_type":"series"},{"link_url":"http://cascadeoc.org/wp-content/uploads/2019/12/2019BogSlogCYASplits.pdf","link_type":"splits"},{"link_url":"http://rg.cascadeoc.org/rg2/#275","link_type":"splits"}],"volunteer_roles":[{"role_name":"Control Pickup","individual_id":"019d0a11-4d2f-7e3e-84ed-99c3a92d4ec1","citation_count":1,"individual_name":"Anthony Donahue","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019b815e-cce3-715e-9e1c-27eb8d76b0c0","citation_count":1,"individual_name":"Dave Dummeyer","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a11-4d2f-7780-8db0-47a6d8b7327c","citation_count":1,"individual_name":"Ethan O'Connor","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a11-4d31-7901-b29d-9bde4d91a99d","citation_count":1,"individual_name":"Zoe Sibthorp","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Designer","individual_id":"019d0a11-4d2f-7780-8db0-47a6d8b7327c","citation_count":1,"individual_name":"Ethan O'Connor","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Designer(s)","individual_id":"019d0a11-4d2f-7780-8db0-47a6d8b7327c","citation_count":1,"individual_name":"Ethan O'Connor","volunteer_hours":null,"volunteer_points":null},{"role_name":"Epunch Coordinator","individual_id":"019d