null,"result_id":"019d0f21-20cd-7db4-8d97-7ba763ac32af","time_text":null,"competitive":true,"course_rank":null,"status_code":"DNF","affiliations":[],"outcome_text":"DNF","overall_rank":null,"result_notes":"47:18","category_name":null,"category_rank":null,"individual_id":"019d0a11-4d30-7088-ab6f-edc15d584f0f","metric_summary":null,"competitor_name":"Siri Christopherson","competitor_type":"individual","additional_course":false,"affiliation_labels":[]}],"course_id":"019d0f21-2176-761b-8d7e-93822dc637a0","course_name":"Course4","distance_km":null,"result_count":31,"control_count":null,"course_climb_m":null}],"event_id":"019b81f3-1f4e-7e15-b447-e66539ebcd68","venue_id":"019b7b43-5d8c-7e71-8a6e-fb7e4dcf19cf","event_date":"2019-05-15","event_kind":"race","event_name":"2019 Wednesday Evening #1","venue_name":"University of Washington","event_notes":null,"course_count":4,"event_status":null,"result_count":59,"citation_count":3,"event_comments":"The first event in the 2019 Wednesday Evening Series will be held at the University of Washington, on World Orienteering Day! The Wednesday Evening Series is our most relaxed, casual set of navigation events, held in local parks once the weather warms up. These events are a little more low-key than those in the Winter League, and we typically offer a barbeque afterward for all participants. Decompress after work and bring a coworker or two along. Or meet your family at the park and enjoy a night off from cooking. Or meet a bunch of friends at the park for an evening of exploring together, chatting over some food, and finishing up with frisbee on the lawn.\nEvents in the Wednesday Evening Series are generally less challenging (both physically and navigationally) than many of our other events, and are therefore great for beginners and those less experienced with orienteering – while also offering a challenge to longtime participants of the sport.\nThe University of Washington is one of our most complex and interesting urban venues, with lots of stairways, narrow passages, tight corners, and more! The courses will take you to a number of different areas of campus, with a mixture of long and short legs. Be careful to read your map, plan ahead, and check your descriptions carefully to avoid wrong turns and dead ends.","external_links":[{"link_url":"https://www.google.com/maps/dir//Padelford+Parking+Garage,+Seattle,+WA+98105/@47.656519,-122.305287,16z/data=!4m9!4m8!1m0!1m5!1m1!1s0x5490148d952916ab:0x3c88b4a574258d33!2m2!1d-122.3033006!2d47.6570352!3e0?hl=en-US","link_type":"directions"},{"link_url":"https://cascadeoc.org/event/2019-wednesday-evening-series-1-university-washington/","link_type":"event_page"},{"link_url":"https://cascadeoc.org/map/university-of-washington/","link_type":"map"},{"link_url":"http://rg.cascadeoc.org/rg2/#249","link_type":"routegadget"},{"link_url":"https://cascadeoc.org/series/wednesday-evening/","link_type":"series"},{"link_url":"http://obasen.orientering.se/winsplits/online/en/default.asp?page=classes&databaseId=62592","link_type":"splits"}],"volunteer_roles":[{"role_name":"Control Pickup","individual_id":"019d0a11-4d2f-7123-a52b-c8c1f7949bee","citation_count":1,"individual_name":"Cameron Devine","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a40-c41a-770d-ac5a-2a93a9da9e55","citation_count":1,"individual_name":"Evan Derickson","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a11-4d2f-736d-863f-5e546e61e969","citation_count":1,"individual_name":"Ing Uhlin","volunteer_hours":null,"volunteer_points":null},{"role_name":"Control Pickup","individual_id":"019d0a11-4d30-710f-b42f-ecba537a7836","citation_count":1,"individual_name":"Ott Toomet","volunteer_hours":null,"volunteer_points":null},{"role_name":"Course Designer","individual_id":"019b7ac9-920b-7530-b85a-103e52302ff8","citation_count":1,"individual_name":"Will Enger","volunteer_hours":null,"volunteer_points":null},{"role